# Entorno: development o production
ENVIRONMENT=development
DEBUG=true

# Proveedor activo: sqlserver, sqlserverexpress, localdb, postgres, mysql, mariadb
DB_PROVIDER=postgres

# SQL Server (formato ODBC)
#DB_SQLSERVER=Driver={ODBC Driver 17 for SQL Server};Server=MI_SERVIDOR;Database=mi_bd;Trusted_Connection=yes;TrustServerCertificate=yes;
DB_SQLSERVER=Driver={ODBC Driver 17 for SQL Server};Server=LAPTOP-PRP44KEV;Database=bdfacturas_sqlserver_local;Trusted_Connection=yes;TrustServerCertificate=yes;

# SQL Server Express (formato ODBC)
#DB_SQLSERVEREXPRESS=Driver={ODBC Driver 17 for SQL Server};Server=MI_SERVIDOR;Database=mi_bd;Trusted_Connection=yes;TrustServerCertificate=yes;
DB_SQLSERVEREXPRESS=Driver={ODBC Driver 17 for SQL Server};Server=LAPTOP-PRP44KEV\SQLEXPRESS;Database=bdfacturas_sqlserverexpress_local;Trusted_Connection=yes;TrustServerCertificate=yes;

# SQL Server LocalDB (solo desarrollo)
#DB_LOCALDB=Driver={ODBC Driver 17 for SQL Server};Server=(localdb)\MSSQLLocalDB;Database=mi_bd;Trusted_Connection=yes;TrustServerCertificate=yes;
DB_LOCALDB=Driver={ODBC Driver 17 for SQL Server};Server=(localdb)\MSSQLLocalDB;Database=bdfacturas_localdb_local;Trusted_Connection=yes;TrustServerCertificate=yes;

# PostgreSQL (formato URL)
#DB_POSTGRES=postgresql+asyncpg://usuario:password@localhost:5432/mi_bd
DB_POSTGRES=postgresql+asyncpg://postgres:postgres@localhost:5432/innovacion_curricular

# MySQL
#DB_MYSQL=Server=localhost;Port=3306;Database=mi_bd;User=root;Password=mi_password;CharSet=utf8mb4;
DB_MYSQL=Server=localhost;Port=3306;Database=bdfacturas_mysql_local;User=root;Password=mysql;CharSet=utf8mb4;

# MariaDB
#DB_MARIADB=Server=localhost;Port=3306;Database=mi_bd;User=root;Password=;
DB_MARIADB=Server=localhost;Port=3306;Database=bdfacturas_mariadb_local;User=root;Password=;
